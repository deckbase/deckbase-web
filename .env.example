NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_META_PIXEL_ID=
# Google Analytics 4 — Measurement ID from Admin → Data streams (format G-XXXXXXXXXX). Omit to disable client-side GA.
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_IOS_APP_ID=
NEXT_PUBLIC_ANDROID_PACKAGE_NAME=
# Canonical site origin (no trailing slash). OAuth issuer is {NEXT_PUBLIC_SITE_URL}/api/mcp/oauth — set per environment:
#   local dev: http://localhost:3000
#   production: https://www.deckbase.co
NEXT_PUBLIC_SITE_URL=
INDEXNOW_KEY=
NEXT_PUBLIC_REVENUECAT_WEB_API_KEY=
# Comma-separated Firebase user emails. Gates /dashboard/admin nav, admin pages, and SEO/ASO/API/admin/phrases routes.
ADMIN_EMAILS=
ASSEMBLYAI_API_KEY=
ANTHROPIC_API_KEY=
FAL_KEY=
# Used for TTS and for GET /v1/voices (MCP list_elevenlabs_voices + GET /api/elevenlabs/voices).
ELEVENLABS_API_KEY=
ELEVENLABS_DEFAULT_VOICE_ID=
DECKBASE_API_KEY=
# Cursor MCP (hosted HTTPS only): set in your environment so .cursor/mcp.json can resolve ${env:DECKBASE_MCP_API_KEY}
DECKBASE_MCP_API_KEY=
# Firebase Admin — required for server APIs. MCP OAuth stores auth codes + refresh tokens in Firestore (same project).
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
# Private key: paste full PEM; use \n for line breaks in a single env value.
FIREBASE_ADMIN_PRIVATE_KEY=
FIREBASE_STORAGE_BUCKET=

# MCP OAuth (optional). If MCP_OAUTH_JWT_SECRET is unset or shorter than 32 chars, OAuth and discovery return 503; dashboard API keys still work on POST /api/mcp.
# Generate a secret: openssl rand -base64 32
MCP_OAUTH_JWT_SECRET=
# Optional. Public clients + PKCE only. Omit to use built-in clients (client_id "deckbase", Cursor + localhost + {SITE_URL}/mcp/oauth/callback).
# MCP_OAUTH_CLIENTS=[{"client_id":"deckbase","redirect_uris":["cursor://anysphere.cursor-mcp/oauth/callback","http://127.0.0.1","http://localhost","http://localhost:3000","https://www.deckbase.co/mcp/oauth/callback"]}]

# Optional GEO / E-E-A-T schema fields. When NEXT_PUBLIC_FOUNDER_NAME is set,
# app/layout.js emits a Person node and links it as Organization.founder.
NEXT_PUBLIC_FOUNDER_NAME=
NEXT_PUBLIC_FOUNDER_URL=
# Comma-separated URLs, e.g. https://x.com/founder,https://www.linkedin.com/in/founder
NEXT_PUBLIC_FOUNDER_SAME_AS=
