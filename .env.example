# Firebase (client)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

NEXT_PUBLIC_META_PIXEL_ID=
ADMIN_EMAILS=

# YouTube transcript + speaker diarization — https://www.assemblyai.com/
ASSEMBLYAI_API_KEY=

# DataForSEO — https://app.dataforseo.com/api-access (Keywords Data / Search Volume)
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# Firecrawl — https://firecrawl.dev (site scraping → markdown)
FIRECRAWL_API_KEY=

# Perplexity — https://docs.perplexity.ai (keyword strategy research, Sonar API)
PERPLEXITY_API_KEY=
# GA4 & Search Console — service account JSON (stringify the key file) or set GOOGLE_APPLICATION_CREDENTIALS to key file path
# Enable APIs: Google Analytics Data API, Search Console API. Add service account email to GA4 (Viewer) and Search Console (Full/Restricted).
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/key.json
GOOGLE_SERVICE_ACCOUNT_JSON=
GA4_PROPERTY_ID=
GSC_SITE_URL=

# ASO Command Center — current store listing as baseline for keyword analysis
# Google Play: same service account as above; enable "Google Play Android Developer API", grant access in Play Console → API access
ANDROID_PACKAGE_NAME=
# App Store Connect: Users and Access → Integrations → App Store Connect API → create key, download .p8
APPSTORE_CONNECT_ISSUER_ID=
APPSTORE_CONNECT_KEY_ID=
APPSTORE_CONNECT_PRIVATE_KEY=
APPSTORE_APP_ID=
APPSTORE_BUNDLE_ID=

# Wizard: AI concept + image
ANTHROPIC_API_KEY=
FAL_KEY=

# ElevenLabs TTS — https://elevenlabs.io
ELEVENLABS_API_KEY=
ELEVENLABS_DEFAULT_VOICE_ID=
# Mobile app API auth: set DECKBASE_API_KEY and send X-API-Key header on add-with-ai and ElevenLabs. (Dashboard API keys are for MCP only.)
DECKBASE_API_KEY=

# Firebase Admin (server) — for voice-sample cache in Storage (tts-samples/)
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=
# Bucket name only, no gs:// (e.g. your-project.firebasestorage.app or your-project.appspot.com)
FIREBASE_STORAGE_BUCKET=

# RevenueCat Web (subscriptions) — Public API Key from RevenueCat dashboard > Web Billing app
NEXT_PUBLIC_REVENUECAT_WEB_API_KEY=
# RevenueCat Secret API Key (server-only). Required in production to enforce AI = subscription.
# From RevenueCat dashboard > Project Settings > API Keys. Used to verify entitlement server-side.
REVENUECAT_SECRET_KEY=
# Set REQUIRE_PRO_FOR_AI=false on Vercel Preview (or dev) to skip Pro/VIP check for add-with-ai. Production should leave unset or true.
# REQUIRE_PRO_FOR_AI=
