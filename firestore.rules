rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: only the owning user
    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    // User profile and app data
    match /users/{userId} {
      allow read, write: if isOwner(userId);
      match /inAppNotifications/{notificationId} {
        allow read, write: if isOwner(userId);
      }
    }

    // Decks, cards, templates (flashcards collection abolished)
    match /users/{userId}/decks/{deckId} {
      allow read, write: if isOwner(userId);
    }
    match /users/{userId}/cards/{cardId} {
      allow read, write: if isOwner(userId);
    }
    match /users/{userId}/templates/{templateId} {
      allow read, write: if isOwner(userId);
    }

    // Card media (images, audio) — path: users/{uid}/media/{mediaId}
    match /users/{userId}/media/{mediaId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Sync is state-based: users/{uid}/decks and users/{uid}/cards only (no ops collection).

    match /free_trials/{userId} {
      allow read, write: if isOwner(userId);
    }
  }
}
